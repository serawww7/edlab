{
  "name": "edlab-seo-autofix",
  "version": "1.0.0",
  "private": true,
  "description": "Автовиправлення SEO-тегів для EDLab (GitHub Pages)",
  "scripts": {
    "fix-meta": "node scripts/fix-meta.js",
    "seo-optimize": "node scripts/seo-optimize.js",
    "audit-links": "node scripts/audit-links.js",
    "verify-seo": "node scripts/verify-seo.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "apply-core": "node scripts/apply-core.js",
    "dedup-css": "node scripts/dedup-vs-core.js --apply",
    "build-manifest": "node scripts/build-manifest.js",
    "wcag-labels": "node scripts/fix-wcag-labels.js",
    "wcag-meta": "node scripts/ensure-meta-desc.js",
    "wcag-contrast": "node scripts/fix-lesson-contrast.js",
    "build": "npm run apply-core && npm run fix-meta && npm run dedup-css && npm run build-manifest && npm run generate-sitemap && npm run wcag-meta"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12",
    "glob": "10.3.10"
  }
}
